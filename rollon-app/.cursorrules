## Common Patterns

### Creating a new component with variants:
```typescript
import { cva, type VariantProps } from 'class-variance-authority';
import { cn } from '@/lib/utils';

const componentVariants = cva("base-classes", {
  variants: {
    variant: {
      default: "default-styles",
      outlined: "outlined-styles",
    },
    size: {
      sm: "h-8 px-3",
      lg: "h-12 px-8",
    },
  },
  defaultVariants: {
    variant: "default",
    size: "default",
  },
});

export function Component({ 
  className, 
  variant, 
  size 
}: React.ComponentProps<"div"> & 
  VariantProps<typeof componentVariants>) {
  return (
    <div className={cn(componentVariants({ variant, size }), className)}>
      {/* content */}
    </div>
  );
}
```

### Using Zustand store:
```typescript
import { useStoreName } from '@/store/storeName';

function Component() {
  const { items, addItem } = useStoreName();
  // ...
}
```
